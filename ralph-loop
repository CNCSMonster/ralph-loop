#!/bin/bash

# Ralph Loop - 极简自动化开发循环
# 用法: ./ralph-loop init     初始化项目结构
#       ./ralph-loop run [N]  启动循环（N=最大迭代次数，默认50）

set -e

PROMPT_FILE="PROMPT.md"
RALPH_DIR=".ralph"
DOCS_DIR="$RALPH_DIR/docs"
CONSTRAINTS_FILE="$RALPH_DIR/constraints.md"
PLAN_FILE="$RALPH_DIR/plan.md"
PROGRESS_FILE="$RALPH_DIR/progress.md"
VERIFY_FILE="$RALPH_DIR/verify.md"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log()  { echo -e "${BLUE}[ralph-loop]${NC} $1"; }
ok()   { echo -e "${GREEN}[✓]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
err()  { echo -e "${RED}[✗]${NC} $1"; }

# 初始化项目结构（幂等，不会覆盖已有文件）
cmd_init() {
    log "初始化 Ralph Loop 项目结构..."

    mkdir -p "$RALPH_DIR" "$DOCS_DIR"

    if [ ! -f "$CONSTRAINTS_FILE" ]; then
        cat > "$CONSTRAINTS_FILE" << 'EOF'
# Ralph Loop 约束文件

**警告：此文件定义了 Ralph Loop 的工作规则，AI Agent 必须严格遵守，不得修改此文件。**

## 概念

- **总任务**: PROMPT.md 中的完整需求
- **子任务**: AI 分解总任务后的可执行步骤，记录在 plan.md
- **子任务验证**: 完成一个子任务后的局部验证
- **整体验证**: 所有子任务完成后对总任务的最终验证

## 工作流程

每次启动按顺序执行：

```
1. 读取 PROMPT.md、constraints.md、plan.md
2. 判断计划是否需要调整，需要则修改 plan.md
3. 选择下一个未完成的子任务（见选择策略）
4. 实现该子任务
5. 运行子任务验证 → 更新 plan.md passes:true/false
6. 更新 progress.md（做了什么、发现了什么）
7. 更新 verify.md 阶段标识
8. 所有子任务 passes:true → 进入整体验证
9. 整体验证通过 → 验证次数+1；失败 → 归零并修复
10. 验证次数达到 3 次 → 输出 <promise>COMPLETE</promise>
11. 提交代码变更
```

## 文件管理

**plan.md** - 子任务状态（核心）
- 子任务格式：`- [ ] task-001 描述 (priority:1, passes:false)`
- `[ ]` = 未完成，`[x]` = 完成；`passes:true/false` = 验证状态
- 脚本通过正则 `passes:(true|false)` 统计

**progress.md** - 每次迭代追加记录

**verify.md** - 记录验证次数、阶段和结果

## plan.md 格式

```markdown
# 工作计划

## 总任务
...

## 子任务分解
...

## 子任务列表
- [ ] task-001 描述 (priority:1, passes:false)
- [x] task-002 描述 (priority:2, passes:true)

## 调整历史
...
```

**关键**：子任务行不能注释块内，必须含 `task-NNN`、`priority:N`、`passes:true/false`

## 子任务选择

- 选 `passes:false` 且 `[ ]` 的子任务
- 优先 priority 数值最小，其次 ID 最小

## 验证规则

**子任务验证**：完成一个子任务后验证
- 通过 → 标记 `passes:true`，**不更新验证次数**
- 失败 → 保持 `passes:false`，记录到 progress.md

**整体验证**：所有子任务 passes:true 后执行
- 通过 → 验证次数 +1
- 失败 → 次数归零，将涉及的子任务标记回 `passes:false`，调整计划

## 阶段标识

每次迭代更新 verify.md 中的 `## 当前阶段:`：
- `子任务执行中`：还有 passes:false 的子任务
- `整体验证中`：全部 passes:true，验证次数 < 3
- `已完成`：全部 passes:true 且验证次数 >= 3

## 完成条件

同时满足时输出 `<promise>COMPLETE</promise>`：
- 所有子任务 passes:true
- 验证次数达到 3 次

## 代码提交

每次迭代提交变更，格式：`[ralph-loop] 完成子任务: {标题} (迭代 #{N})`

## 禁止行为

- ❌ 不得修改 constraints.md
- ❌ 不得一次迭代完成多个子任务
- ❌ 不得未验证就标记 passes:true
- ❌ 不得在子任务完成前更新验证次数

## 文件权限

| 文件 | AI 可修改 |
|------|----------|
| constraints.md | ❌ |
| plan.md | ✅ |
| progress.md | ✅ |
| verify.md | ✅ |
| .ralph/docs/ | ✅ |
| PROMPT.md | ❌ |
EOF
        ok "$CONSTRAINTS_FILE"
    else
        warn "$CONSTRAINTS_FILE 已存在，跳过"
    fi

    if [ ! -f "$PLAN_FILE" ]; then
        cat > "$PLAN_FILE" << 'EOF'
# 工作计划

## 总任务

<!-- 从 PROMPT.md 提炼的总任务描述 -->

## 子任务分解

<!-- AI 将总任务分解为子任务的思路 -->

## 子任务列表

<!-- AI 将总任务分解为子任务，格式必须遵守：
每行以 - [ ] 或 - [x] 开头，包含 task-NNN ID、priority:N 和 passes:true/false
例如：- [ ] task-001 子任务描述 (priority:1, passes:false)
注意：子任务行不能在注释块内，否则脚本无法统计
-->

## 调整历史

EOF
        ok "$PLAN_FILE"
    else
        warn "$PLAN_FILE 已存在，跳过"
    fi

    if [ ! -f "$PROGRESS_FILE" ]; then
        cat > "$PROGRESS_FILE" << 'EOF'
# 进度记录

## 迭代日志

EOF
        ok "$PROGRESS_FILE"
    else
        warn "$PROGRESS_FILE 已存在，跳过"
    fi

    if [ ! -f "$VERIFY_FILE" ]; then
        cat > "$VERIFY_FILE" << 'EOF'
# 验证记录

## 当前阶段: 子任务执行中

## 验证次数: 0/3

## 验证日志

EOF
        ok "$VERIFY_FILE"
    else
        warn "$VERIFY_FILE 已存在，跳过"
    fi

    echo ""
    ok "初始化完成"
}

# 检查是否已初始化
check_initialized() {
    if [ ! -f "$PROMPT_FILE" ]; then
        err "PROMPT.md 不存在，请先编写总任务描述"
        exit 1
    fi
    if [ ! -f "$CONSTRAINTS_FILE" ]; then
        err "项目未初始化，请先运行: ralph-loop init"
        exit 1
    fi
    if [ ! -f "$PLAN_FILE" ] || [ ! -f "$PROGRESS_FILE" ] || [ ! -f "$VERIFY_FILE" ]; then
        err "状态文件不完整，请检查项目结构"
        exit 1
    fi
}

# 构建 prompt
build_prompt() {
    local iteration=$1
    local max=$2
    cat << EOF
你是一个 Ralph Loop AI Agent。

请严格遵守以下约束规则（禁止修改 .ralph/constraints.md）：
$(cat "$CONSTRAINTS_FILE")

---

当前是第 $iteration 次迭代（上限 $max）。

总任务描述：
$(cat "$PROMPT_FILE")

---

请按照约束规则执行子任务。
EOF
}

# 获取子任务统计（从 plan.md 正则提取）
get_task_stats() {
    if [ ! -f "$PLAN_FILE" ]; then
        echo "0 0 0"
        return
    fi

    local total done_count pending_count

    # 只统计以 - [ ] 或 - [x] 开头的实际子任务行（排除注释中的示例）
    done_count=$(grep -cE '^\s*-\s*\[x\].*passes:true' "$PLAN_FILE" 2>/dev/null || true)
    pending_count=$(grep -cE '^\s*-\s*\[\s\].*passes:false' "$PLAN_FILE" 2>/dev/null || true)
    done_count=${done_count:-0}
    pending_count=${pending_count:-0}
    total=$((done_count + pending_count))

    echo "$total $done_count $pending_count"
}

# 检查是否完成（规则判断）
check_complete() {
    read -r total done_count pending_count <<< "$(get_task_stats)"

    # 规则: 所有子任务 passes:true 且 整体验证次数 >= 3
    if [ "$total" -gt 0 ] && [ "$pending_count" -eq 0 ]; then
        local verify_count=$(get_verify_count)
        if [ "$verify_count" -ge 3 ]; then
            return 0
        fi
    fi

    return 1
}

# 获取验证次数
get_verify_count() {
    grep -oP '验证次数: \K[0-9]+' "$VERIFY_FILE" 2>/dev/null || echo "0"
}

# 获取当前阶段
get_phase() {
    read -r total done_count pending_count <<< "$(get_task_stats)"
    local verify_count=$(get_verify_count)

    if [ "$total" -gt 0 ] && [ "$pending_count" -eq 0 ]; then
        if [ "$verify_count" -ge 3 ]; then
            echo "已完成"
        else
            echo "整体验证中"
        fi
    else
        echo "子任务执行中"
    fi
}

# 更新阶段标识到 verify.md
update_phase() {
    local phase=$(get_phase)
    if [ -f "$VERIFY_FILE" ]; then
        sed -i "s/## 当前阶段: .*/## 当前阶段: $phase/" "$VERIFY_FILE"
    fi
}

# 启动循环
cmd_run() {
    local max=${1:-50}
    local iteration=0

    check_initialized

    log "Ralph Loop 启动 (最大迭代次数: $max)"
    echo ""

    while [ $iteration -lt $max ]; do
        iteration=$((iteration + 1))

        # 获取当前阶段和统计信息
        local phase=$(get_phase)
        read -r total done_count pending_count <<< "$(get_task_stats)"
        local verify_count=$(get_verify_count)

        log "========== 迭代 $iteration/$max =========="

        if [ "$phase" = "子任务执行中" ]; then
            log "当前阶段: 子任务执行中 ($done_count/$total 已完成)"
        elif [ "$phase" = "整体验证中" ]; then
            log "当前阶段: 整体验证中 (验证次数: $verify_count/3)"
        else
            log "当前阶段: 已完成"
        fi

        build_prompt "$iteration" "$max" > /tmp/ralph-prompt.txt

        log "运行 qwen (迭代 $iteration/$max)..."

        cat /tmp/ralph-prompt.txt | qwen --yolo

        # 更新阶段标识
        update_phase

        # 规则: 全部子任务通过 且 整体验证3次 → 结束
        if check_complete; then
            ok "总任务完成！所有子任务已通过，整体验证连续 3 次通过。"
            exit 0
        fi
    done

    warn "达到最大迭代次数 ($max)"
    exit 1
}

# 显示帮助
cmd_help() {
    echo "用法:"
    echo "  ralph-loop init          初始化项目结构（幂等，不覆盖已有文件）"
    echo "  ralph-loop run [N]       启动循环，N 为最大迭代次数（默认 50）"
    echo "  ralph-loop status        生成状态分析 prompt，交给 qwen-code 分析"
    echo "  ralph-loop help          显示此帮助"
    echo ""
    echo "文件:"
    echo "  PROMPT.md                  总任务描述（你需要编写的唯一文件）"
    echo "  .ralph/constraints.md      AI 约束规则（自动生成，禁止修改）"
    echo "  .ralph/plan.md             计划与子任务状态（AI 更新）"
    echo "  .ralph/progress.md         进度记录（AI 更新）"
    echo "  .ralph/verify.md           验证记录（AI 更新）"
    echo "  .ralph/docs/               子任务 spec（AI 可选）"
}

# 显示状态
cmd_status() {
    check_initialized

    read -r total done_count pending_count <<< "$(get_task_stats)"

    cat > /tmp/ralph-status-prompt.txt << PROMPT
你是一个 Ralph Loop 状态分析助手。请读取以下文件内容，分析当前项目状态。

## 约束规则（.ralph/constraints.md）
$(cat "$CONSTRAINTS_FILE")

---

## 当前阶段: $(get_phase)

## 子任务统计
- 子任务总数: $total
- 已完成: $done_count
- 待完成: $pending_count

## 计划（.ralph/plan.md）
$(cat "$PLAN_FILE")

## 进度记录（.ralph/progress.md）
$(cat "$PROGRESS_FILE")

## 验证记录（.ralph/verify.md）
$(cat "$VERIFY_FILE")

---

请分析：
1. 当前处于哪个阶段（子任务执行中/整体验证中/已完成）
2. 子任务完成度（$done_count/$total）
3. 整体验证次数（当前 $(get_verify_count)/3）
4. 下一步应该做什么
5. 是否有任何问题或阻塞
PROMPT

    log "状态分析 Prompt 已生成到 /tmp/ralph-status-prompt.txt"
    echo ""
    log "运行 qwen 分析状态..."
    echo ""

    cat /tmp/ralph-status-prompt.txt | qwen --yolo
    echo ""
}

# 路由命令
case "${1:-help}" in
    init)
        cmd_init
        ;;
    run)
        cmd_run "${2:-50}"
        ;;
    status)
        cmd_status
        ;;
    help|--help|-h)
        cmd_help
        ;;
    *)
        err "未知命令: $1"
        cmd_help
        exit 1
        ;;
esac
